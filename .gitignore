# =====================================================
# CESC 450 – Real-Time Embedded Systems Project
# .gitignore
# =====================================================

# -----------------------------------------------------
# Build artifacts (do NOT commit generated files)
# -----------------------------------------------------
build/*
!build/README.md

# Generic build outputs
*.o
*.obj
*.elf
*.out
*.bin
*.hex
*.map
*.d
*.a

# -----------------------------------------------------
# Compiler / toolchain artifacts
# -----------------------------------------------------
*.log
*.tmp
*.swp
*.swo

# -----------------------------------------------------
# IDE / editor files
# -----------------------------------------------------
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

.idea/
*.iml

# -----------------------------------------------------
# OS-specific files
# -----------------------------------------------------
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Linux
*~

# -----------------------------------------------------
# Python / scripting artifacts (if used for tooling)
# -----------------------------------------------------
__pycache__/
*.pyc

# -----------------------------------------------------
# Node / tooling artifacts (if used)
# -----------------------------------------------------
node_modules/

# -----------------------------------------------------
# Test / coverage artifacts (if added later)
# -----------------------------------------------------
coverage/
*.gcda
*.gcno

# -----------------------------------------------------
# Misc
# -----------------------------------------------------
*.bak
*.old
